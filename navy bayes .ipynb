import pandas as pd

conditional_probs={}

def prior_prob(df):
    counts=df.iloc[:,target_idx].value_counts()
    total=len(df)
    probabilities=counts/total
    return probabilities

def conditional_prob(df,feature_idx,target_idx):
    classes=df.iloc[:,target_idx].unique()
    feature_values=df.iloc[:,feature_idx].unique()
    feature_name=df.columns[feature_idx]
    for cls in classes:
        if cls not in conditional_probs:
            conditional_probs[cls]={}
        if feature_name not in conditional_probs[cls]:
            conditional_probs[cls][feature_name]={}
        filtered_df=df[df.iloc[:,target_idx]==cls]
        total=len(filtered_df)
        print("\nClass:",cls)
        for value in feature_values:
            count=len(filtered_df[filtered_df.iloc[:,feature_idx]==value])
            probability=count/total
            conditional_probs[cls][feature_name][value]=probability
            print(value,count,probability)

