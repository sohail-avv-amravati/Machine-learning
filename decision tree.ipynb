import pandas as pd
import math

def entropy(index,pd):
    values=pd.iloc[:,index].value_counts()
    ent=0
    total=sum(values)
    for count in values:
        p=count/total
        ent=ent-(p*math.log2(p))
    return ent

def entropy_a(attr_index,target_index,pd):
    ent_w=0
    total=len(pd)
    for value in pd.iloc[:,attr_index].unique():
        subset=pd[pd.iloc[:,attr_index]==value]
        sub_size=len(subset)
        ent_a=0
        target_counts=subset.iloc[:,target_index].value_counts()
        for count in target_counts:
            p=count/sub_size
            ent_a=ent_a-(p*math.log2(p))
        ent_w=ent_w+(sub_size/total)*ent_a
    return ent_w

def information_gain(pd):
    c_count=len(pd.columns)
    class_lable=c_count-1
    base_entropy=entropy(class_lable,pd)
    b=-1
    inde=-1
    for i in range(class_lable):
        info_gain=base_entropy-entropy_a(i,class_lable,pd)
        print("information gain of",pd.columns[i],"is",info_gain)
        if info_gain>b:
            b=info_gain
            inde=i
    print("Next Node :",pd.columns[inde])
    return inde

